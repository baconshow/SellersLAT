rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES - PROTOTYPING MODE
     * 
     * Core Philosophy:
     * This ruleset implements a strict User-Ownership model. Access to data is restricted 
     * exclusively to the user who created it. This is enforced through direct field 
     * checks on documents to ensure high performance and low cost.
     * 
     * Data Structure:
     * - /projects/{projectId}: Root collection for client projects.
     * - /projects/{projectId}/phases/{phaseId}: Subcollection for project milestones.
     * - /projects/{projectId}/weeklyUpdates/{weeklyUpdateId}: Subcollection for progress tracking.
     * 
     * Key Security Decisions:
     * 1. Denormalization for Authorization: To avoid expensive 'get()' calls, the 'ownerId' 
     *    (representing the project creator's UID) is denormalized from the Project into all 
     *    Phase and WeeklyUpdate documents.
     * 2. Strict Ownership: No public reading or listing is permitted. All access requires 
     *    authentication and matching ownership IDs.
     * 3. Relational Integrity: On creation, the rules enforce that the document's 
     *    internal owner field matches the authenticated user's UID.
     * 4. Prototyping Flexibility: While authorization is strictly enforced, the specific 
     *    data types and schema of non-authorization fields are not validated to allow 
     *    for rapid frontend iteration.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the provided UID matches the authenticated user's UID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is the owner and the document exists (for updates/deletes). */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the top-level Projects collection.
     * @path /projects/{projectId}
     * @allow (create) if auth.uid == 'user123' and request.resource.data.userId == 'user123'
     * @deny (list) if auth.uid is different from the document's userId.
     * @principle Enforces document ownership for all CRUD operations.
     */
    match /projects/{projectId} {
      // Owner: acesso completo
      allow get: if isOwner(resource.data.userId);
      allow list: if isOwner(resource.data.userId)
                  || (isSignedIn() && resource.data.shareEnabled == true);

      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      allow update: if isExistingOwner(resource.data.userId)
                    && request.resource.data.userId == resource.data.userId // Enforce immutability of owner
                    // Gestores autorizados podem atualizar (comentários em distribuidores)
                    || (isSignedIn() && resource.data.shareEnabled == true);

      allow delete: if isExistingOwner(resource.data.userId);

      /**
       * @description Rules for Phases within a Project.
       * @path /projects/{projectId}/phases/{phaseId}
       * @allow (get) if auth.uid matches the denormalized 'ownerId' field.
       * @deny (update) if attempting to change the 'ownerId' field.
       * @principle Uses denormalized ownership for independent, high-performance authorization.
       */
      match /phases/{phaseId} {
        allow get, list: if isOwner(resource.data.ownerId);
        
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
        
        allow update: if isExistingOwner(resource.data.ownerId) 
                      && request.resource.data.ownerId == resource.data.ownerId;
        
        allow delete: if isExistingOwner(resource.data.ownerId);
      }

      /**
       * @description Rules for Weekly Updates within a Project.
       * @path /projects/{projectId}/weeklyUpdates/{weeklyUpdateId}
       * @allow (create) if the incoming 'ownerId' matches the authenticated user.
       * @deny (delete) if the user is not the established owner.
       * @principle Authorization Independence: No parent lookup required due to denormalized ownerId.
       */
      match /weeklyUpdates/{weeklyUpdateId} {
        allow get, list: if isOwner(resource.data.ownerId);

        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;

        allow update: if isExistingOwner(resource.data.ownerId)
                      && request.resource.data.ownerId == resource.data.ownerId;

        allow delete: if isExistingOwner(resource.data.ownerId);
      }

      /**
       * @description Rules for Distributors subcollection.
       * @path /projects/{projectId}/distributors/{distributorId}
       * Owner: full CRUD. Gestores autorizados (shareEnabled): read + update (hasUnreadComment).
       */
      match /distributors/{distributorId} {
        allow read, write: if isSignedIn()
                           && request.auth.uid == get(/databases/$(database)/documents/projects/$(projectId)).data.userId;
        allow read, update: if isSignedIn()
                            && get(/databases/$(database)/documents/projects/$(projectId)).data.shareEnabled == true;

        /**
         * @description Comments on a distributor — written by external gestores.
         * @path /projects/{projectId}/distributors/{distributorId}/comments/{commentId}
         */
        match /comments/{commentId} {
          allow read: if isSignedIn()
                      && (request.auth.uid == get(/databases/$(database)/documents/projects/$(projectId)).data.userId
                          || get(/databases/$(database)/documents/projects/$(projectId)).data.shareEnabled == true);
          allow create: if isSignedIn();
        }
      }
    }

    // Explicitly deny access to any other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}