rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES - PROTOTYPING MODE
     *
     * Core Philosophy:
     * This ruleset implements an Owner + Members model. Access to data is restricted
     * to the user who created the project (ownerId) OR users whose email is in the
     * project's members[] array. Public read is allowed for shared projects.
     *
     * Data Structure:
     * - /projects/{projectId}: Root collection for client projects.
     * - /projects/{projectId}/phases/{phaseId}: Subcollection for project milestones.
     * - /projects/{projectId}/weeklyUpdates/{weeklyUpdateId}: Subcollection for progress tracking.
     * - /projects/{projectId}/distributors/{distributorId}: Subcollection for distributors.
     * - /projects/{projectId}/distributors/{distributorId}/comments/{commentId}: Comments from gestores.
     *
     * Key Security Decisions:
     * 1. Owner + Members: ownerId (UID) or members[] (array-contains email) grants full access.
     * 2. Legacy userId: kept for backward compatibility (old projects without ownerId).
     * 3. Public Share: Projects with shareEnabled == true can be read (get) without auth.
     * 4. Prototyping Flexibility: Non-authorization fields are not schema-validated.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isMember(data) {
      return isSignedIn()
        && data.members != null
        && data.members.hasAny([request.auth.token.email]);
    }

    function isOwnerOrMember(data) {
      return isOwner(data.ownerId) || isOwner(data.userId) || isMember(data);
    }

    // --- Collection Rules ---

    match /projects/{projectId} {
      // Read: owner, member, or public shared
      allow get: if isOwnerOrMember(resource.data);
      allow get: if resource.data.shareEnabled == true;

      // List: owner or member (for dashboard queries)
      // Also allow list for authenticated + shareEnabled (query by slug)
      allow list: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || resource.data.ownerId == request.auth.uid
        || (resource.data.members != null && resource.data.members.hasAny([request.auth.token.email]))
        || resource.data.shareEnabled == true
      );

      // Create: authenticated, sets self as owner
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      // Update: owner or member (immutable userId/ownerId)
      // Also allow authenticated gestor on shared project (for comments)
      allow update: if isOwnerOrMember(resource.data);
      allow update: if isSignedIn() && resource.data.shareEnabled == true;

      // Delete: owner only
      allow delete: if isSignedIn() && (
        isOwner(resource.data.ownerId) || isOwner(resource.data.userId)
      );

      // --- Phases subcollection ---
      match /phases/{phaseId} {
        allow get, list: if isOwner(resource.data.ownerId);
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
        allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid
                      && request.resource.data.ownerId == resource.data.ownerId;
        allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      }

      // --- Weekly Updates subcollection ---
      match /weeklyUpdates/{weeklyUpdateId} {
        allow get, list: if isOwner(resource.data.ownerId);
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
        allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid
                      && request.resource.data.ownerId == resource.data.ownerId;
        allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      }

      // --- Distributors subcollection ---
      match /distributors/{distributorId} {
        // Owner or member: full CRUD
        allow read, write: if isSignedIn() && (
          request.auth.uid == get(/databases/$(database)/documents/projects/$(projectId)).data.userId
          || request.auth.uid == get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId
          || (
            get(/databases/$(database)/documents/projects/$(projectId)).data.members != null
            && get(/databases/$(database)/documents/projects/$(projectId)).data.members.hasAny([request.auth.token.email])
          )
        );

        // Shared project: read for anyone (public API), update for authenticated gestores
        allow read: if get(/databases/$(database)/documents/projects/$(projectId)).data.shareEnabled == true;
        allow update: if isSignedIn()
                      && get(/databases/$(database)/documents/projects/$(projectId)).data.shareEnabled == true;

        // --- Comments on distributors ---
        match /comments/{commentId} {
          // Owner/member can read
          allow read: if isSignedIn() && (
            request.auth.uid == get(/databases/$(database)/documents/projects/$(projectId)).data.userId
            || request.auth.uid == get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId
            || (
              get(/databases/$(database)/documents/projects/$(projectId)).data.members != null
              && get(/databases/$(database)/documents/projects/$(projectId)).data.members.hasAny([request.auth.token.email])
            )
          );
          // Shared project: anyone can read
          allow read: if get(/databases/$(database)/documents/projects/$(projectId)).data.shareEnabled == true;

          // Any authenticated user can create comments
          allow create: if isSignedIn();
        }
      }

      // --- Messages subcollection (chat entre membros) ---
      match /messages/{messageId} {
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/projects/$(projectId)).data.members.hasAny([request.auth.token.email])
          || get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid
        );
        allow create: if request.auth != null && (
          get(/databases/$(database)/documents/projects/$(projectId)).data.members.hasAny([request.auth.token.email])
          || get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid
        );
      }
    }

    // Explicitly deny access to any other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
